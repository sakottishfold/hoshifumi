# Supabase
# https://supabase.com/dashboard で新規プロジェクト作成 → Settings → API から取得
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# Anthropic Claude API (月次AIレポート生成用、v1.1から必須)
# https://console.anthropic.com/settings/keys から取得
ANTHROPIC_API_KEY=sk-ant-...

# サイトURL (本番はVercelのURL)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Gemini API (Phase 1 AI follow-up question + 月次レポート、ADR-021)
# https://aistudio.google.com/apikey から取得、free tier 15 RPM / 1500 RPD
GEMINI_API_KEY=AIzaSy...

# AI provider 切替(optional、default=gemini)。v1.1+ で "anthropic" に切替可能。
AI_PROVIDER=gemini
